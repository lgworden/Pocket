# Railway injects DATABASE_URL automatically once you attach a Postgres plugin.
DATABASE_URL=postgres://user:pass@localhost:5432/closet_stylist

# console.anthropic.com
ANTHROPIC_API_KEY=

# platform.openai.com — powers the on-demand "sketch this item" feature, which
# redraws an item's photo as a fashion-sketchbook croquis via gpt-image-1
# (Claude reads images but can't generate them). Optional: the sketch button
# just returns a "not configured" message without it; nothing else depends on it.
OPENAI_API_KEY=

# Optional: Railway volume or S3-compatible bucket for item photos
PHOTO_STORAGE_URL=
PHOTO_STORAGE_KEY=

# console.cloud.google.com — OAuth client used for BOTH "Sign in with Google" and
# calendar read access. GOOGLE_REDIRECT_URI must exactly match an Authorized redirect
# URI on that OAuth client (protocol/host/port). In production set it to
# https://YOUR-APP.up.railway.app/api/auth/google/callback (see DEPLOYMENT.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# console.cloud.google.com — separate API key (Distance Matrix API enabled, billing-
# enabled project) used to estimate travel time between back-to-back calendar events
# and the user's home address. Optional — the schedule-conflict check just no-ops
# without it.
GOOGLE_MAPS_API_KEY=

# Signs the session cookie (Google Sign-In). Generate a random 32+ byte hex string,
# e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
# Rotating this value invalidates every active session (logs everyone out).
SESSION_SECRET=

# Shared secret for the Railway cron job that hits POST /api/cron/tick every
# 15 min (schedule: */15 * * * *) to fire notifications. Generate any random
# string and set the cron job's curl command to send it as
# `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=

# Comma-separated emails allowed to view /admin/metrics (internal analytics
# dashboard). Leave unset to disable the page for everyone (including you).
ADMIN_EMAILS=

# sentry.io — DSN for error tracking (Project Settings -> Client Keys (DSN)).
# Leave unset to no-op error reporting locally.
SENTRY_DSN=

# Optional — only needed for readable (un-minified) stack traces in Sentry via
# source-map upload at build time. Leave all three unset to skip this; error
# reporting itself only needs SENTRY_DSN above.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
